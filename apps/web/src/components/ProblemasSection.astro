---
import Badge from "./ui/Badge.astro";
import type { ProblemasContent } from "../lib/content/home";

interface Props {
  content: ProblemasContent;
}

const { content } = Astro.props;
---

<section id="problemas">
  <div class="container">
    <div class="section-header reveal">
      <Badge variant="gradient">{content.badge}</Badge>
      <h2 class="headline">{content.headline}</h2>
      <p class="body-text">{content.body}</p>
    </div>

    <div class="risk-grid">
      {
        content.items.map((problem) => (
          <div class="risk-card reveal">
            <span class="risk-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={problem.icon}
              />
            </span>
            <p class="risk-label">{problem.label}</p>
            <span class="risk-num">{problem.num}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  section {
    background: var(--surface-dark);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    /* inline clamp: section uses tighter vertical rhythm than --section-pad-y (40→96px);
       this sub-section pattern (~56→80px) appears only here — not yet a token candidate */
    padding: clamp(3.5rem, 8vw, 5rem) var(--gutter);
  }

  /* Section header */
  .section-header {
    max-width: 760px;
    margin-bottom: clamp(1.75rem, 4vw, 2.5rem);
  }

  .headline {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-h2);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-tight);
    color: var(--utk-white);
    margin: var(--space-4) 0 0;
    text-wrap: balance;
  }

  .body-text {
    font-size: var(--fs-lg);
    line-height: 1.6;
    color: var(--text-on-dark-muted);
    margin: 14px 0 0;
  }

  /* Risk items grid */
  .risk-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }

  @media (min-width: 640px) {
    .risk-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .risk-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Individual risk card */
  .risk-card {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 18px 20px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition:
      border-color var(--dur-base) var(--ease-out),
      background var(--dur-base) var(--ease-out);
  }

  .risk-card:hover {
    border-color: rgba(124, 58, 237, 0.4);
    background: rgba(124, 58, 237, 0.06);
  }

  .risk-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 11px;
    background: linear-gradient(
      135deg,
      rgba(124, 58, 237, 0.22),
      rgba(20, 184, 166, 0.22)
    );
    border: 1px solid rgba(124, 58, 237, 0.3);
    color: var(--utk-white);
  }

  .risk-label {
    flex: 1;
    font-size: var(--fs-sm);
    line-height: 1.4;
    color: var(--utk-slate-200);
    font-weight: var(--fw-medium);
    margin: 0;
  }

  .risk-num {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: var(--fw-semibold);
    letter-spacing: 0.04em;
    color: rgba(148, 163, 184, 0.45);
  }

  /* Grid stagger for scroll-driven animation */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .risk-grid > .reveal:nth-child(3n + 2) {
        animation-range: entry 0% cover 30%;
      }
      .risk-grid > .reveal:nth-child(3n) {
        animation-range: entry -4% cover 34%;
      }
    }
  }
</style>
