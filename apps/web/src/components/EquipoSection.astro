---
import Badge from "./ui/Badge.astro";
import type { EquipoContent } from "../lib/content/home";

interface Props {
  content: EquipoContent;
}

const { content } = Astro.props;

const linkedinIconPath =
  '<path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>';
---

<section id="equipo">
  <img
    src="/assets/pattern-hexagonal.png"
    alt=""
    class="hex-pattern"
    aria-hidden="true"
  />
  <div class="container">
    <div class="section-header reveal">
      <Badge variant="cyan">{content.badge}</Badge>
      <h2 class="headline">{content.headline}</h2>
      <p class="body-text">{content.body}</p>
    </div>

    <div class="team-grid">
      {
        content.members.map((member) => (
          <div class="team-card reveal">
            <div class="avatar-ring">
              <img
                src={member.photo}
                alt={member.name}
                width="84"
                height="84"
                class="avatar"
                loading="lazy"
              />
            </div>
            <h3 class="member-name">{member.name}</h3>
            <div class="member-specialty">
              <Badge variant="purple">{member.specialty}</Badge>
            </div>
            <p class="member-exp">{member.exp}</p>
            <p class="member-bio">{member.bio}</p>
            <div class="member-links">
              <a
                href={member.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="linkedin-link"
                aria-label={`LinkedIn de ${member.name}`}
              >
                <svg
                  viewBox="0 0 24 24"
                  width="16"
                  height="16"
                  fill="currentColor"
                  set:html={linkedinIconPath}
                />
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  section {
    background: var(--surface-dark);
    position: relative;
    overflow: hidden;
  }

  .hex-pattern {
    position: absolute;
    right: 0;
    top: 0;
    height: 100%;
    width: 44%;
    object-fit: cover;
    opacity: 0.55;
    -webkit-mask-image: linear-gradient(270deg, transparent, #000 70%);
    mask-image: linear-gradient(270deg, transparent, #000 70%);
    pointer-events: none;
  }

  .container {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--section-pad-y) var(--gutter);
  }

  .section-header {
    max-width: 720px;
    margin-bottom: var(--section-header-mb);
  }

  .headline {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-h2);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-tight);
    color: var(--utk-white);
    margin: var(--space-4) 0 0;
    text-wrap: balance;
  }

  .body-text {
    font-size: var(--fs-lg);
    line-height: 1.6;
    color: var(--text-on-dark-muted);
    margin: 16px 0 0;
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .team-card {
    position: relative;
    padding: 32px 30px;
    border-radius: 16px;
    background: rgba(30, 41, 59, 1);
    border: 1px solid rgba(51, 65, 85, 1);
    transition:
      border-color var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
  }

  .team-card:hover {
    border-color: rgba(124, 58, 237, 0.5);
    transform: translateY(-4px);
  }

  .avatar-ring {
    width: 84px;
    height: 84px;
    border-radius: 50%;
    padding: 2px;
    background: linear-gradient(135deg, var(--utk-purple), var(--utk-cyan));
    margin-bottom: var(--space-5);
    flex-shrink: 0;
  }

  .avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    background: var(--surface-dark);
  }

  .member-name {
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: 20px;
    color: var(--utk-white);
    margin: 0;
  }

  .member-specialty {
    margin-top: 12px;
  }

  .member-specialty :global(.badge--purple) {
    background: var(--utk-white);
    color: var(--utk-purple);
    border-color: rgba(124, 58, 237, 0.3);
  }

  .member-exp {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-on-dark-muted);
    margin: 14px 0 0;
    line-height: 1;
  }

  .member-bio {
    font-size: var(--fs-sm);
    line-height: 1.6;
    color: var(--text-on-dark-muted);
    margin: 16px 0 0;
  }

  .member-links {
    display: flex;
    gap: 10px;
    margin-top: 24px;
  }

  .linkedin-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    border: 1.5px solid rgba(51, 65, 85, 1);
    color: var(--text-on-dark-muted);
    text-decoration: none;
    transition:
      border-color var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }

  .linkedin-link:hover {
    border-color: var(--utk-purple);
    color: var(--utk-white);
  }
</style>
