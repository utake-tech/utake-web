---
import Button from "./ui/Button.astro";
import type { ContactoContent } from "../lib/content/home";

interface Props {
  content: ContactoContent;
}

const { content } = Astro.props;
---

<section id="contacto">
  <div class="container">
    <div class="cta-card reveal">
      <img
        src="/assets/texture-hex.png"
        alt=""
        class="texture"
        aria-hidden="true"
      />

      <!-- Izquierda: copy sobre gradiente -->
      <div class="cta-copy">
        <h2 class="headline">{content.headline}</h2>
        <p class="body-text">{content.body}</p>
      </div>

      <!-- Derecha: formulario en white box -->
      <div class="form-card">
        <form id="contact-form" class="contact-form" novalidate>
          <div class="form-field">
            <label for="nombre" class="form-label">Nombre</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              class="form-input"
              placeholder="Tu nombre"
              required
            />
          </div>

          <div class="form-field">
            <label for="empresa" class="form-label">Empresa</label>
            <input
              type="text"
              id="empresa"
              name="empresa"
              class="form-input"
              placeholder="Nombre de tu empresa"
            />
          </div>

          <div class="form-field">
            <label for="correo" class="form-label">Correo</label>
            <input
              type="email"
              id="correo"
              name="correo"
              class="form-input"
              placeholder="hola@empresa.com"
              required
            />
          </div>

          <div class="form-field">
            <label for="reto" class="form-label">Reto técnico</label>
            <textarea
              id="reto"
              name="reto"
              class="form-textarea"
              rows="4"
              placeholder="¿Qué estás construyendo y dónde te está costando? Stack, escala, deuda técnica, plazos…"
              required
            ></textarea>
          </div>

          <Button type="submit" size="md" fullWidth>{content.cta}</Button>
          <p class="cta-note">{content.ctaNote}</p>
          <p id="form-error" class="form-msg form-msg--error" aria-live="polite" hidden></p>
        </form>

        <div id="form-success" class="form-success" hidden>
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <h3 class="success-title">¡Mensaje enviado!</h3>
          <p class="success-body">Te contactamos en menos de 24 horas.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    background: var(--surface-page);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--section-pad-y) var(--gutter);
  }

  /* ── Gradient card wrapper ──────────────────────────────────────────── */

  .cta-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-2xl);
    background: linear-gradient(135deg, var(--utk-purple), var(--utk-blue) 50%, var(--utk-cyan));
    padding: clamp(2.5rem, 7vw, 4.25rem) clamp(1.625rem, 6vw, 3.75rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .cta-card {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 52px;
    }
  }

  /* ── Decorative texture ─────────────────────────────────────────────── */

  .texture {
    position: absolute;
    right: -40px;
    bottom: -60px;
    width: 46%;
    opacity: 0.22;
    pointer-events: none;
    user-select: none;
  }

  /* ── Left copy ──────────────────────────────────────────────────────── */

  .cta-copy {
    position: relative;
  }

  .headline {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-h2);
    line-height: 1.1;
    letter-spacing: var(--ls-tight);
    color: var(--utk-white);
    margin: 0;
    text-wrap: balance;
  }

  .body-text {
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.92);
    margin: 18px 0 0;
    max-width: 440px;
  }

  /* ── Right form card ────────────────────────────────────────────────── */

  .form-card {
    position: relative;
    background: var(--utk-white);
    border-radius: 18px;
    padding: clamp(1.375rem, 4vw, 1.875rem);
    box-shadow: 0 22px 50px rgba(15, 23, 42, 0.18);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-label {
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: 13px;
    color: var(--text-strong);
  }

  .form-input,
  .form-textarea {
    width: 100%;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    border: 2px solid var(--border-default);
    background: var(--utk-white);
    color: var(--text-strong);
    font-family: var(--font-body);
    font-size: var(--fs-base);
    line-height: 1.5;
    outline: none;
    transition:
      border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
    box-sizing: border-box;
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--utk-slate-400);
  }

  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--utk-purple);
    box-shadow: var(--ring-brand);
  }

  .form-textarea {
    resize: vertical;
  }

  .cta-note {
    font-size: 13px;
    line-height: 1.5;
    color: var(--utk-slate-500);
    margin: 0;
    text-align: center;
  }

  .form-msg {
    font-size: var(--fs-sm);
    text-align: center;
    margin: 0;
    border-radius: var(--radius-md);
    padding: 10px 14px;
  }

  .form-msg--error {
    background: rgba(220, 38, 38, 0.08);
    color: var(--color-danger);
    border: 1px solid rgba(220, 38, 38, 0.2);
  }

  .form-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 12px;
    padding: clamp(1.375rem, 4vw, 1.875rem);
    color: var(--utk-purple);
    min-height: 320px;
  }

  .success-title {
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-h4);
    color: var(--utk-slate-900);
    margin: 0;
  }

  .success-body {
    font-size: var(--fs-base);
    color: var(--utk-slate-500);
    margin: 0;
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const successEl = document.getElementById("form-success");
  const errorEl = document.getElementById("form-error");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector<HTMLButtonElement>('[type="submit"]');
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.style.opacity = "0.7";
    }
    if (errorEl) errorEl.hidden = true;

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        body: new FormData(form),
      });

      const json = await res.json();

      if (!res.ok || json.error) {
        if (errorEl) {
          errorEl.textContent = json.error ?? "Error inesperado. Inténtalo de nuevo.";
          errorEl.hidden = false;
        }
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.style.opacity = "";
        }
        return;
      }

      form.hidden = true;
      if (successEl) successEl.hidden = false;
    } catch {
      if (errorEl) {
        errorEl.textContent = "Error de conexión. Inténtalo de nuevo.";
        errorEl.hidden = false;
      }
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.style.opacity = "";
      }
    }
  });
</script>
