---
import Button from "./ui/Button.astro";
import logoIsotipoUrl from "@utake/design-system/assets/logo-isotipo.png?url";
---

<header id="site-nav">
  <nav class="nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="UTAKE TECH — inicio">
      <img src={logoIsotipoUrl} alt="" width="30" height="30" />
      <span class="nav-wordmark">UTAKE <span class="nav-tech">TECH</span></span>
    </a>

    <!-- Desktop nav links -->
    <div class="nav-links" role="navigation" aria-label="Navegación principal">
      <a href="#soluciones" class="nav-link">Servicios</a>
      <a href="#equipo" class="nav-link">Equipo</a>
      <a href="#empezar" class="nav-link">Cómo empezar</a>
    </div>

    <!-- Desktop cluster: CTA -->
    <div class="nav-cluster">
      <Button href="#contacto" variant="primary" size="sm">Agendar reunión</Button>
    </div>

    <!-- Mobile burger -->
    <button id="nav-burger" class="nav-burger" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-mobile-menu">
      <svg id="icon-menu" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="icon-close" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
        <path d="M18 6 6 18"/>
        <path d="m6 6 12 12"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="nav-mobile-menu" class="mobile-menu" aria-hidden="true">
    <a href="#soluciones" class="mobile-link">Servicios</a>
    <a href="#equipo" class="mobile-link">Equipo</a>
    <a href="#empezar" class="mobile-link">Cómo empezar</a>
    <div class="mobile-footer">
      <Button href="#contacto" variant="primary" size="sm" fullWidth>Agendar reunión</Button>
    </div>
  </div>
</header>

<style>
  #site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(15, 23, 42, 0.82);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 72px;
    padding: 0 var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }

  /* Logo */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .nav-logo img {
    height: 30px;
    width: auto;
  }
  .nav-wordmark {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: 19px; /* brand-fixed lockup: no token maps to this exact fixed value */
    letter-spacing: var(--ls-caps);
    color: var(--utk-white);
  }
  .nav-tech {
    color: var(--utk-cyan);
    font-weight: var(--fw-semibold);
  }

  /* Desktop nav links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 30px;
  }
  .nav-link {
    position: relative;
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    color: var(--utk-slate-300);
    text-decoration: none;
    transition: color var(--dur-base) var(--ease-out);
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -7px;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--utk-purple), var(--utk-cyan));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s var(--ease-out);
  }
  .nav-link:hover {
    color: var(--utk-white);
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }

  /* Desktop cluster */
  .nav-cluster {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  /* Language selector */
  .nav-lang {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    height: 36px;
    padding: 0 12px;
    border-radius: var(--radius-md);
    border: 1.5px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.03);
    color: var(--utk-slate-400);
  }
  .lang-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: var(--fw-semibold);
    letter-spacing: 0.02em;
    color: var(--utk-slate-500);
    transition: color var(--dur-base) var(--ease-out);
  }
  .lang-btn.is-active {
    color: var(--utk-white);
  }
  .lang-sep {
    color: rgba(255, 255, 255, 0.2);
    font-size: var(--fs-xs);
    user-select: none;
  }

  /* Mobile burger */
  .nav-burger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 9px;
    border: 1.5px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.04);
    color: var(--utk-slate-200);
    cursor: pointer;
    transition: background var(--dur-base) var(--ease-out);
  }
  .nav-burger:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 10px var(--gutter) 22px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(13, 18, 32, 0.98);
  }
  .mobile-menu.is-open {
    display: flex;
  }
  .mobile-link {
    padding: 13px 0;
    font-size: var(--fs-base);
    font-weight: var(--fw-medium);
    color: var(--utk-slate-300);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .mobile-footer {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 18px;
  }

  /* Responsive breakpoints (canonical: 768px) */
  @media (max-width: 767px) {
    .nav-links {
      display: none;
    }
    .nav-cluster {
      display: none;
    }
    .nav-burger {
      display: inline-flex;
    }
  }
  @media (min-width: 768px) {
    .mobile-menu {
      display: none !important;
    }
  }
</style>

<script>
  const burger = document.getElementById("nav-burger") as HTMLButtonElement | null;
  const menu = document.getElementById("nav-mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  function openMenu() {
    menu?.classList.add("is-open");
    menu?.setAttribute("aria-hidden", "false");
    burger?.setAttribute("aria-expanded", "true");
    if (iconMenu) iconMenu.style.display = "none";
    if (iconClose) iconClose.style.display = "";
  }

  function closeMenu() {
    menu?.classList.remove("is-open");
    menu?.setAttribute("aria-hidden", "true");
    burger?.setAttribute("aria-expanded", "false");
    if (iconMenu) iconMenu.style.display = "";
    if (iconClose) iconClose.style.display = "none";
  }

  burger?.addEventListener("click", () => {
    menu?.classList.contains("is-open") ? closeMenu() : openMenu();
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Language switcher (cosmetic — no translation yet)
  document.querySelectorAll<HTMLButtonElement>("[data-lang]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const lang = btn.dataset.lang;
      document.querySelectorAll<HTMLButtonElement>("[data-lang]").forEach((b) => {
        b.classList.toggle("is-active", b.dataset.lang === lang);
      });
    });
  });
</script>
