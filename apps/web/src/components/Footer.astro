---
import type { FooterContent } from "../lib/content/home";

interface Props {
  content: FooterContent;
}

const { content } = Astro.props;

const logoIsotipoUrl = (await import("@utake/design-system/assets/logo-isotipo.png?url")).default;
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="col-brand">
        <a href="/" class="logo-link" aria-label="UTAKE TECH inicio">
          <img src={logoIsotipoUrl} alt="UTAKE TECH" width="32" height="32" class="logo-img" />
          <span class="wordmark">UTAKE <span class="wordmark-tech">TECH</span></span>
        </a>
        <p class="tagline">{content.tagline}</p>
      </div>

      <div class="col-links">
        <p class="col-title">Disciplina</p>
        <ul role="list" class="link-list">
          {
            content.disciplinaLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link">{link.label}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="col-links">
        <p class="col-title">Empresa</p>
        <ul role="list" class="link-list">
          {
            content.empresaLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link">{link.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="copyright">{content.copyright}</p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--surface-dark);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 5rem) var(--gutter) clamp(1.5rem, 4vw, 2.5rem);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 3rem);
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr;
    }
  }

  /* Brand column */
  .logo-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: var(--space-4);
  }

  .logo-img {
    width: 32px;
    height: 32px;
    border-radius: 6px;
  }

  .wordmark {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: 19px; /* brand-fixed: not tokenizable as fluid */
    letter-spacing: -0.01em;
    color: var(--utk-white);
  }

  .wordmark-tech {
    color: var(--utk-cyan);
  }

  .tagline {
    font-size: var(--fs-sm);
    color: var(--text-on-dark-muted);
    margin: 0;
    line-height: 1.5;
    max-width: 240px;
  }

  /* Link columns */
  .col-title {
    font-size: var(--fs-xs);
    font-weight: var(--fw-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.5);
    margin: 0 0 var(--space-4);
  }

  .link-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-link {
    font-size: var(--fs-sm);
    color: var(--text-on-dark-muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .footer-link:hover {
    color: var(--utk-white);
  }

  /* Bottom bar */
  .footer-bottom {
    padding-top: clamp(1.5rem, 3vw, 2rem);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .copyright {
    font-size: var(--fs-xs);
    color: rgba(148, 163, 184, 0.35);
    margin: 0;
  }
</style>
