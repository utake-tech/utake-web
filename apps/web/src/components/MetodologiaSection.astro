---
import type { MetodologiaContent } from "../lib/content/home";

interface Props {
  content: MetodologiaContent;
}

const { content } = Astro.props;
---

<section id="metodologia">
  <div class="container reveal">
    <p class="quote">
      <span class="quote-main">{content.quoteMain}</span>
      <br />
      <span class="quote-gradient">{content.quoteGradient}</span>
    </p>
    <p class="body-text">{content.body}</p>
    <div class="tags" aria-label="Áreas de pensamiento técnico">
      {
        content.tags.map((tag, i) => (
          <>
            <span class="tag">{tag}</span>
            {i < content.tags.length - 1 && (
              <span class="tag-sep" aria-hidden="true">·</span>
            )}
          </>
        ))
      }
    </div>
  </div>
</section>

<style>
  section {
    background: var(--surface-dark);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .container {
    max-width: 880px;
    margin: 0 auto;
    /* inline clamp: compact manifesto band, distinct rhythm from full sections */
    padding: clamp(2.5rem, 6vw, 3.75rem) var(--gutter);
    text-align: center;
  }

  .quote {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-h3);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-tight);
    margin: 0;
    text-wrap: balance;
  }

  .quote-main {
    color: var(--utk-white);
  }

  .quote-gradient {
    background: linear-gradient(120deg, var(--utk-purple), var(--utk-blue) 52%, var(--utk-cyan));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .body-text {
    font-size: var(--fs-sm);
    line-height: 1.7;
    color: var(--text-on-dark-muted);
    margin: var(--space-5) auto 0;
    max-width: 600px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 10px 18px;
    margin-top: var(--space-4);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    letter-spacing: 0.01em;
    color: var(--utk-slate-300);
  }

  .tag-sep {
    color: var(--utk-cyan);
    font-size: var(--fs-sm);
    line-height: 1;
  }
</style>
