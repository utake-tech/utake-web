---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import HeroSection from "../components/HeroSection.astro";
import ProblemasSection from "../components/ProblemasSection.astro";
import MetodologiaSection from "../components/MetodologiaSection.astro";
import ServiciosSection from "../components/ServiciosSection.astro";
import EquipoSection from "../components/EquipoSection.astro";
import EmpezarSection from "../components/EmpezarSection.astro";
import ContactoSection from "../components/ContactoSection.astro";
import Footer from "../components/Footer.astro";
import {
  heroContent,
  problemasContent,
  metodologiaContent,
  serviciosContent,
  equipoContent,
  empezarContent,
  contactoContent,
  footerContent,
} from "../lib/content/home";
---

<BaseLayout title="UTAKE TECH — Ingeniería de software AI-First">
  <Navbar />
  <HeroSection content={heroContent} />
  <ProblemasSection content={problemasContent} />
  <MetodologiaSection content={metodologiaContent} />
  <ServiciosSection content={serviciosContent} />
  <EquipoSection content={equipoContent} />
  <EmpezarSection content={empezarContent} />
  <ContactoSection content={contactoContent} />
  <Footer content={footerContent} />
</BaseLayout>

<style is:global>
  body {
    background: var(--surface-dark);
  }
</style>
